# =====================================
# HiveCore Bot — Environment Variables
# =====================================

# ---- Discord ----
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here
# Application client ID
DISCORD_CLIENT_ID=your_application_client_id_here
# Optional: comma-separated guild IDs for instant slash command deployment during dev.
# Leave empty for global deployment (takes up to 1 hour to propagate).
DISCORD_DEV_GUILD_IDS=

# ---- Pterodactyl Panel ----
# Base URL of your Pterodactyl panel (no trailing slash)
PTERO_PANEL_URL=https://panel.example.com
# Application API key (Admin → Application API). Required for admin operations.
PTERO_APP_API_KEY=ptla_your_application_api_key_here
# Client API key (used for the global server-management fallback when a user has not linked a personal key)
PTERO_CLIENT_API_KEY=ptlc_your_client_api_key_here

# ---- Account Generator ----
# Email domain for generated accounts (format: random@<domain>)
ACCOUNT_EMAIL_DOMAIN=therynzo.in
# Default panel role for generated accounts: "user" (default) or "admin"
ACCOUNT_DEFAULT_ROLE=user

# ---- Auto-Provisioning Defaults (used by the shop) ----
# Default Pterodactyl egg ID (e.g., Vanilla Minecraft is commonly 1 on the Minecraft nest)
PTERO_DEFAULT_EGG_ID=1
# Default nest ID
PTERO_DEFAULT_NEST_ID=1
# Default location ID where servers will be deployed
PTERO_DEFAULT_LOCATION_ID=1
# Docker image to use for deployed servers
PTERO_DEFAULT_DOCKER_IMAGE=ghcr.io/pterodactyl/yolks:java_17
# Startup command for deployed servers
PTERO_DEFAULT_STARTUP=java -Xms128M -Xmx{{SERVER_MEMORY}}M -jar {{SERVER_JARFILE}}
# Default environment variables for the egg (JSON object)
PTERO_DEFAULT_ENV={"SERVER_JARFILE":"server.jar","VANILLA_VERSION":"latest","BUILD_NUMBER":"latest"}

# ---- Bot Configuration ----
# Comma-separated list of Discord user IDs treated as bot owners (full admin)
OWNER_IDS=
# Comma-separated list of role IDs treated as bot admins (in addition to server admins)
ADMIN_ROLE_IDS=
# Default channel ID where the auto-updating node status panel will be posted
NODE_STATUS_CHANNEL_ID=
# How often (in minutes) the node status panel updates
NODE_STATUS_INTERVAL_MIN=3
# Channel ID for error/audit logs (optional)
LOG_CHANNEL_ID=

# ---- Economy Tuning ----
DAILY_REWARD_MIN=20
DAILY_REWARD_MAX=50
WORK_REWARD_MIN=40
WORK_REWARD_MAX=75
WORK_COOLDOWN_MIN=30
ROB_COOLDOWN_MIN=30
ROB_SUCCESS_RATE=0.45
BANK_DEPOSIT_FEE=0.02
BANK_WITHDRAW_FEE=0.01
BANK_LIMIT=50000

# ---- Database ----
# SQLite file path (relative to project root or absolute)
DATABASE_PATH=./data/hivecore.db

# ---- Logging ----
# Levels: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
